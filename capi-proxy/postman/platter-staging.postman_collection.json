{
  "info": {
    "name": "Platter Staging — Full API Suite",
    "description": "End-to-end tests for the Platter payment→provision flow.\n\nBefore running:\n1. Import the companion environment file (platter-staging.postman_environment.json)\n2. Fill in all {{...}} variables in that environment\n3. Run the collection in order — each folder is one layer of the stack",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [],
  "item": [
    {
      "name": "1. Secret API (joinsecret.com)",
      "description": "Tests the perks provisioning API directly. Run these first to confirm your API key is valid before testing the webhook handler.",
      "item": [
        {
          "name": "Auth — Get JWT",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('Response has token', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('token');",
                  "  pm.collectionVariables.set('secret_jwt', json.token);",
                  "  console.log('JWT set:', json.token.slice(0, 20) + '...');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{perks_private_api_key}}" }
            ],
            "url": {
              "raw": "https://www.joinsecret.com/api/v1/authentications",
              "protocol": "https",
              "host": ["www", "joinsecret", "com"],
              "path": ["api", "v1", "authentications"]
            },
            "description": "Exchanges the PERKS_PRIVATE_API_KEY for a short-lived JWT. The JWT is automatically saved to {{secret_jwt}} for use in the next request."
          }
        },
        {
          "name": "Provision User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 2xx', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "pm.test('Response has email', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('email');",
                  "  console.log('User:', json.email, '| already_exists:', json.already_exists);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{secret_jwt}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{test_email}}\"\n}"
            },
            "url": {
              "raw": "https://www.joinsecret.com/api/v1/users",
              "protocol": "https",
              "host": ["www", "joinsecret", "com"],
              "path": ["api", "v1", "users"]
            },
            "description": "Creates (or finds existing) user on the perks portal. This is idempotent — safe to run multiple times with the same email."
          }
        }
      ]
    },
    {
      "name": "2. Staging Webhook — staging-provision-perks",
      "description": "Tests the /api/staging-provision-perks endpoint. Uses HMAC SHA256 (pre-request script) to sign payloads with RAZORPAY_WEBHOOK_SECRET_TEST.",
      "item": [
        {
          "name": "GET → 405 (method guard)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 405', () => pm.response.to.have.status(405));"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            }
          }
        },
        {
          "name": "POST no signature → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error in body', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_test_nosig\",\n        \"email\": \"{{test_email}}\",\n        \"amount\": 18000,\n        \"currency\": \"INR\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            },
            "description": "No x-razorpay-signature header — should be rejected."
          }
        },
        {
          "name": "POST wrong signature → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "deadbeefdeadbeefdeadbeef" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {\n    \"payment\": {\n      \"entity\": {\n        \"id\": \"pay_test_badsig\",\n        \"email\": \"{{test_email}}\",\n        \"amount\": 18000,\n        \"currency\": \"INR\",\n        \"status\": \"captured\"\n      }\n    }\n  }\n}"
            },
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            }
          }
        },
        {
          "name": "POST non-payment event (correct sig) → 200 ignored",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('razorpay_webhook_secret_test');",
                  "const body = JSON.stringify({ event: 'refund.created', payload: {} });",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                  "pm.environment.set('_computed_sig', sig);",
                  "pm.environment.set('_computed_body', body);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status=ignored', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('ignored');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "{{_computed_sig}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{_computed_body}}"
            },
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            },
            "description": "Webhook for an event type the handler doesn't care about. Should return 200 with status=ignored."
          }
        },
        {
          "name": "POST payment.captured (correct sig) → 200 provisioned ✅",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('razorpay_webhook_secret_test');",
                  "const paymentId = 'pay_test_' + Date.now();",
                  "const email = pm.environment.get('test_email');",
                  "const payload = JSON.stringify({",
                  "  event: 'payment.captured',",
                  "  payload: {",
                  "    payment: {",
                  "      entity: {",
                  "        id: paymentId,",
                  "        email: email,",
                  "        amount: 18000,",
                  "        currency: 'INR',",
                  "        status: 'captured',",
                  "        description: 'Platter Annual'",
                  "      }",
                  "    }",
                  "  }",
                  "});",
                  "const sig = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "pm.environment.set('_computed_sig', sig);",
                  "pm.environment.set('_computed_body', payload);",
                  "console.log('Signing payment event for:', email, '| payment:', paymentId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status=provisioned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('provisioned');",
                  "  pm.expect(json.email).to.be.a('string');",
                  "  console.log('Provisioned:', json.email, '| already_exists:', json.already_exists);",
                  "});",
                  "pm.test('email matches test email', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.email).to.eql(pm.environment.get('test_email'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "{{_computed_sig}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{_computed_body}}"
            },
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            },
            "description": "THE KEY TEST — simulates a full Razorpay payment.captured webhook with a correctly computed HMAC signature. Should auth with Secret API and provision the test user."
          }
        },
        {
          "name": "POST payment.captured missing email → 400",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('razorpay_webhook_secret_test');",
                  "const body = JSON.stringify({",
                  "  event: 'payment.captured',",
                  "  payload: { payment: { entity: { id: 'pay_test_noemail', amount: 18000 } } }",
                  "});",
                  "const sig = CryptoJS.HmacSHA256(body, secret).toString(CryptoJS.enc.Hex);",
                  "pm.environment.set('_computed_sig', sig);",
                  "pm.environment.set('_computed_body', body);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error in body', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('error');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "{{_computed_sig}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{_computed_body}}"
            },
            "url": {
              "raw": "{{staging_url}}/api/staging-provision-perks",
              "host": ["{{staging_url}}"],
              "path": ["api", "staging-provision-perks"]
            }
          }
        }
      ]
    },
    {
      "name": "3. Production Webhook — provision-perks",
      "description": "Same tests against the production endpoint. Uses RAZORPAY_WEBHOOK_SECRET (live). ⚠️ The end-to-end test here will provision a real user.",
      "item": [
        {
          "name": "POST wrong signature → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "deadbeef" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"event\": \"payment.captured\",\n  \"payload\": {}\n}"
            },
            "url": {
              "raw": "{{production_url}}/api/provision-perks",
              "host": ["{{production_url}}"],
              "path": ["api", "provision-perks"]
            }
          }
        },
        {
          "name": "POST payment.captured (correct LIVE sig) → 200 provisioned",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "const secret = pm.environment.get('razorpay_webhook_secret_live');",
                  "const email = pm.environment.get('test_email');",
                  "const payload = JSON.stringify({",
                  "  event: 'payment.captured',",
                  "  payload: {",
                  "    payment: {",
                  "      entity: {",
                  "        id: 'pay_prod_test_' + Date.now(),",
                  "        email: email,",
                  "        amount: 18000,",
                  "        currency: 'INR',",
                  "        status: 'captured'",
                  "      }",
                  "    }",
                  "  }",
                  "});",
                  "const sig = CryptoJS.HmacSHA256(payload, secret).toString(CryptoJS.enc.Hex);",
                  "pm.environment.set('_computed_sig', sig);",
                  "pm.environment.set('_computed_body', payload);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('status=provisioned', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.status).to.eql('provisioned');",
                  "  console.log('Provisioned:', json.email, '| already_exists:', json.already_exists);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-razorpay-signature", "value": "{{_computed_sig}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{{_computed_body}}"
            },
            "url": {
              "raw": "{{production_url}}/api/provision-perks",
              "host": ["{{production_url}}"],
              "path": ["api", "provision-perks"]
            },
            "description": "⚠️ Uses LIVE webhook secret. Will actually provision the test_email on joinsecret.com."
          }
        }
      ]
    },
    {
      "name": "4. Meta CAPI Proxy — /api/events",
      "description": "Tests the Facebook Conversions API proxy.",
      "item": [
        {
          "name": "OPTIONS preflight → 204",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ],
          "request": {
            "method": "OPTIONS",
            "header": [
              { "key": "Origin", "value": "https://platter.bitroot.org" },
              { "key": "Access-Control-Request-Method", "value": "POST" }
            ],
            "url": {
              "raw": "{{staging_url}}/api/events",
              "host": ["{{staging_url}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "POST allowed origin + valid payload → 200",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200 or 400 (no token in staging is ok)', () => {",
                  "  pm.expect(pm.response.code).to.be.oneOf([200, 400, 500]);",
                  "});",
                  "pm.test('ACAO header set for allowed origin', () => {",
                  "  const acao = pm.response.headers.get('Access-Control-Allow-Origin');",
                  "  pm.expect(acao).to.eql('https://platter.bitroot.org');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "https://platter.bitroot.org" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": [\n    {\n      \"event_name\": \"PageView\",\n      \"event_time\": {{$timestamp}},\n      \"action_source\": \"website\",\n      \"user_data\": {\n        \"client_ip_address\": \"1.2.3.4\",\n        \"client_user_agent\": \"Mozilla/5.0\"\n      }\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{staging_url}}/api/events",
              "host": ["{{staging_url}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "POST disallowed origin → no ACAO header",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('No ACAO header for disallowed origin', () => {",
                  "  const acao = pm.response.headers.get('Access-Control-Allow-Origin');",
                  "  pm.expect(acao).to.be.null;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "https://evil.example.com" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": []\n}"
            },
            "url": {
              "raw": "{{staging_url}}/api/events",
              "host": ["{{staging_url}}"],
              "path": ["api", "events"]
            }
          }
        },
        {
          "name": "POST missing data array → 400",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 400', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Origin", "value": "https://platter.bitroot.org" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"wrong_key\": \"no data array here\"\n}"
            },
            "url": {
              "raw": "{{staging_url}}/api/events",
              "host": ["{{staging_url}}"],
              "path": ["api", "events"]
            }
          }
        }
      ]
    }
  ]
}
