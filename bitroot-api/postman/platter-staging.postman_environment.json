{
  "id": "platter-staging-env",
  "name": "Platter — Staging",
  "_postman_variable_scope": "environment",
  "values": [
    {
      "key": "staging_url",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Vercel staging deployment URL, e.g. https://bitroot-org-website-git-staging-bitroot.vercel.app"
    },
    {
      "key": "production_url",
      "value": "https://bitroot.org",
      "type": "default",
      "enabled": true,
      "description": "Production base URL"
    },
    {
      "key": "perks_private_api_key",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Secret (joinsecret.com) private API key — from the Secret dashboard"
    },
    {
      "key": "razorpay_webhook_secret_test",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Razorpay test-mode webhook secret — set in Razorpay Dashboard → Webhooks (test mode)"
    },
    {
      "key": "razorpay_webhook_secret_live",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "Razorpay live-mode webhook secret — set in Razorpay Dashboard → Webhooks (live mode)"
    },
    {
      "key": "test_email",
      "value": "test+platter-ci@bitroot.org",
      "type": "default",
      "enabled": true,
      "description": "Email address used for provision tests — must be reachable or an alias you control"
    },
    {
      "key": "secret_jwt",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Auto-populated by the 'POST /v1/authentications' request. Do not set manually."
    }
